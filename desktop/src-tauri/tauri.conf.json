{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoxelDash One",
  "version": "1.2.0-19",
  "identifier": "dev.voxeldash.desktop",
  "build": {
    "frontendDist": "../splash",
    "beforeBuildCommand": "npm run build:assets"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoxelDash One",
        "url": "index.html",
        "width": 1280,
        "height": 820,
        "minWidth": 940,
        "minHeight": 600,
        "center": true,
        "decorations": false,
        "transparent": false,
        "visible": false,
        "backgroundColor": "#0b0b0f"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "nsis", "msi"],
    "category": "Utility",
    "shortDescription": "Manage and create Minecraft servers",
    "longDescription": "Create, run and manage Minecraft servers from a single desktop app.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/voxeldash-one"
    ],
    "resources": {
      "webui": "webui"
    }
  }
}
